{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "__EVOMASTER_WORKSPACES__"
      ],
      "env": {
        "DEBUG": "false"
      }
    },
    "search_web": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_web.py"
      ],
      "env": {
        "SERPER_API_KEY": "${SERPER_API_KEY}"
      }
    },
    "search_github": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_github.py"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      }
    },
    "search_huggingface": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_huggingface.py"
      ],
      "env": {
        "HF_TOKEN": "HF_TOKEN_PLACEHOLDER",
        "HF_ENDPOINT": "https://hf-mirror.com",
        "HF_HUB_URL": "https://hf-mirror.com",
        "HF_HOME": "${HF_HOME}",
        "HF_DATASETS_CACHE": "${HF_HOME}/datasets",
        "HUGGINGFACE_HUB_CACHE": "${HF_HOME}/hub",
        "HF_HTTP_RETRIES": "4",
        "HF_HTTP_BACKOFF": "1.0",
        "HF_SANDBOX_URL": "http://localhost:8899"
      }
    },
    "search_scholar": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_scholar.py"
      ],
      "env": {
        "SERPER_API_KEY": "${SERPER_API_KEY}"
      }
    }
  }
}
