{
  "mcpServers": {
    "operate_submission": {
      "command": "python",
      "args": [
        "search_dataset_tools/operate_submission/for_datanode.py"
      ],
      "env": {
        "ML_MASTER_DATA_ROOT": "${DATA_ROOT}",
        "ML_MASTER_DATA_EXPID": "multi-modal-gesture-recognition",
        "ML_MASTER_GRADING_SERVERS": "http://127.0.0.1:58683"
      }
    },
    "memory_tree": {
      "command": "python",
      "args": [
        "search_dataset_tools/memory_tree_interface.py"
      ],
      "env": {
        "ML_MASTER_DATA_ROOT": "${DATA_ROOT}",
        "ML_MASTER_DATA_EXPID": "multi-modal-gesture-recognition",
        "ML_MASTER_GRADING_SERVERS": "http://127.0.0.1:58683"
      }
    },
    "search_web": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_web.py"
      ],
      "env": {
        "SERPER_API_KEY": "${SERPER_API_KEY}"
      }
    },
    "search_github": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_github.py"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      }
    },
    "search_huggingface": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_huggingface.py"
      ],
      "env": {
        "HF_TOKEN": "HF_TOKEN_PLACEHOLDER",
        "HF_ENDPOINT": "https://hf-mirror.com",
        "HF_HOME": "${HF_HOME}"
      }
    },
    "search_scholar": {
      "command": "python",
      "args": [
        "search_dataset_tools/search_scholar.py"
      ],
      "env": {
        "SERPER_API_KEY": "${SERPER_API_KEY}"
      }
    },
    "visual": {
      "command": "python",
      "args": [
        "search_dataset_tools/visual.py"
      ],
      "env": {
        "IMAGE_MODEL_API_KEY": "${IMAGE_MODEL_API_KEY}",
        "IMAGE_MODEL_BASE_URL": "https://api.gpugeek.com/v1"
      }
    }
  }
}